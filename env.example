import uuid
from datetime import datetime

from sqlalchemy import Column, DateTime, Float, ForeignKey, String
from sqlalchemy.orm import relationship

from app.db.database import Base
from app.db.types import GUID


class EmissionRecord(Base):
    """Stores the calculated emissions for a resource at a point in time."""

    __tablename__ = "emission_records"

    id = Column(GUID(), primary_key=True, default=uuid.uuid4)
    resource_id = Column(GUID(), ForeignKey("cloud_resources.id"), nullable=False)

    energy_kwh = Column(Float, nullable=False)
    co2_kg = Column(Float, nullable=False)
    region = Column(String, nullable=False)
    provider = Column(String, nullable=False)
    calculated_at = Column(DateTime, default=datetime.utcnow)

    resource = relationship("CloudResource")
